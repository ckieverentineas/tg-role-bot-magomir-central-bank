{
  "name": "telegram-role-bot-magomir-central-bank",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram role-play banking bot for Magomir Central Bank.",
  "engines": {
    "node": ">=20.11.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
