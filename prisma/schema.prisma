generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int              @id @default(autoincrement())
  telegramId           BigInt           @unique
  username             String?
  displayName          String
  characterName        String?
  className            String?
  spec                 String?
  activeAllianceId     Int?
  isPrivate            Boolean          @default(false)
  notificationsEnabled Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  activeAlliance       Alliance?        @relation("UserActiveAlliance", fields: [activeAllianceId], references: [id], onDelete: SetNull)
  memberships          AllianceMember[]
  balances             Balance[]
  sentTransfers        SbpTransfer[]    @relation("TransferSender")
  receivedTransfers    SbpTransfer[]    @relation("TransferReceiver")
  purchases            ShopPurchase[]
  inventory            InventoryItem[]
  createdLogTargets    LogTarget[]      @relation("LogTargetCreator")

  @@index([activeAllianceId])
}

model Alliance {
  id             Int                 @id @default(autoincrement())
  name           String
  slug           String              @unique
  telegramChatId BigInt?
  isHidden       Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  activeUsers    User[]              @relation("UserActiveAlliance")
  members        AllianceMember[]
  faculties      Faculty[]
  currencies     Currency[]
  shops          Shop[]
  sbpRules       SbpTransferRule[]
  transfers      SbpTransfer[]
  logTargets     LogTarget[]
}

model AllianceMember {
  id         Int      @id @default(autoincrement())
  allianceId Int
  userId     Int
  facultyId  Int?
  role       String   @default("MEMBER")
  className  String?
  spec       String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty    Faculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  @@unique([allianceId, userId])
  @@index([userId])
  @@index([facultyId])
}

model Currency {
  id                Int               @id @default(autoincrement())
  allianceId        Int
  name              String
  symbol            String
  symbolCustomEmojiId String?
  isTransferEnabled Boolean           @default(true)
  sortOrder         Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  alliance          Alliance          @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  balances          Balance[]
  sbpRules          SbpTransferRule[]
  transfers         SbpTransfer[]
  shopItems         ShopItem[]

  @@unique([allianceId, name])
  @@index([allianceId, sortOrder])
}

model Faculty {
  id                  Int              @id @default(autoincrement())
  allianceId          Int
  name                String
  symbol              String
  symbolCustomEmojiId String?
  sortOrder           Int              @default(0)
  isHidden            Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  alliance            Alliance         @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  members             AllianceMember[]

  @@unique([allianceId, name])
  @@index([allianceId, sortOrder])
  @@index([allianceId, isHidden])
}

model Balance {
  id         Int      @id @default(autoincrement())
  userId     Int
  currencyId Int
  amount     Decimal  @default(0)
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency   Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@unique([userId, currencyId])
}

model SbpTransferRule {
  id                Int             @id @default(autoincrement())
  allianceId        Int
  currencyId        Int?
  minAmount         Decimal         @default(0)
  maxAmount         Decimal
  periodAmountLimit Decimal?
  periodKind        String          @default("UNLIMITED")
  periodSeconds     Int?
  startsAt          DateTime?
  endsAt            DateTime?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  alliance          Alliance        @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  currency          Currency?       @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@index([allianceId, currencyId, isActive])
}

model SbpTransfer {
  id             Int            @id @default(autoincrement())
  allianceId     Int
  currencyId     Int
  senderUserId   Int
  receiverUserId Int
  amount         Decimal
  status         String         @default("COMPLETED")
  comment        String?
  createdAt      DateTime       @default(now())

  alliance       Alliance       @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  currency       Currency       @relation(fields: [currencyId], references: [id], onDelete: Cascade)
  sender         User           @relation("TransferSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  receiver       User           @relation("TransferReceiver", fields: [receiverUserId], references: [id], onDelete: Cascade)

  @@index([senderUserId, currencyId, createdAt])
  @@index([receiverUserId, currencyId, createdAt])
}

model Shop {
  id          Int            @id @default(autoincrement())
  allianceId  Int
  name        String
  image       String?
  isHidden    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  alliance    Alliance       @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  categories  ShopCategory[]
  items       ShopItem[]

  @@unique([allianceId, name])
}

model ShopCategory {
  id        Int        @id @default(autoincrement())
  shopId    Int
  name      String
  image     String?
  sortOrder Int        @default(0)
  isHidden  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items     ShopItem[]

  @@unique([shopId, name])
  @@index([shopId, sortOrder])
}

model ShopItem {
  id                     Int             @id @default(autoincrement())
  shopId                 Int
  categoryId             Int?
  currencyId             Int
  name                   String
  description            String?
  image                  String?
  price                  Decimal
  stock                  Int?
  isHidden               Boolean         @default(false)
  minQuantity            Int             @default(1)
  maxQuantityPerPurchase Int             @default(1)
  periodQuantityLimit    Int?
  limitPeriodKind        String          @default("UNLIMITED")
  limitPeriodSeconds     Int?
  limitStartsAt          DateTime?
  limitEndsAt            DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  shop                   Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category               ShopCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  currency               Currency        @relation(fields: [currencyId], references: [id], onDelete: Cascade)
  purchases              ShopPurchase[]
  inventoryItems         InventoryItem[]

  @@unique([shopId, name])
  @@index([shopId, isHidden])
}

model ShopPurchase {
  id         Int            @id @default(autoincrement())
  userId     Int
  itemId     Int
  quantity   Int
  totalPrice Decimal
  status     String         @default("COMPLETED")
  createdAt  DateTime       @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  item       ShopItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  inventory  InventoryItem?

  @@index([userId, itemId, createdAt])
}

model InventoryItem {
  id         Int           @id @default(autoincrement())
  userId     Int
  itemId     Int
  purchaseId Int?          @unique
  quantity   Int           @default(1)
  comment    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item       ShopItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  purchase   ShopPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model LogTarget {
  id              Int             @id @default(autoincrement())
  allianceId      Int?
  scope           String
  eventType       String
  chatId          BigInt
  topicId         Int?
  title           String?
  isActive        Boolean         @default(true)
  sourceTargetId  Int?
  createdByUserId Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  alliance        Alliance?       @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  sourceTarget    LogTarget?      @relation("LogTargetMirror", fields: [sourceTargetId], references: [id], onDelete: SetNull)
  mirrorTargets   LogTarget[]     @relation("LogTargetMirror")
  createdBy       User?           @relation("LogTargetCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([allianceId, eventType, scope, isActive])
  @@index([sourceTargetId])
  @@unique([scope, allianceId, eventType, chatId, topicId])
}
